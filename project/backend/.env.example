# 后端本地运行模板
# 复制为 project/backend/.env 后再填写，禁止将真实数据库密码和 AI Key 提交到 Git

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me_database_password
DB_NAME=ai_project

ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=replace_with_your_api_key
ARK_MODEL=replace_with_your_model_id

PORT=3000
