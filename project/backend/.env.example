# 后端本地运行模板
# 复制为 project/backend/.env 后再填写，严禁将真实数据库密码和 AI Key 提交到 Git

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me_database_password
DB_NAME=ai_project

ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=replace_with_your_api_key
ARK_MODEL=replace_with_your_model_id

# Phase 1 认证配置
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=8h

# Phase 2 AI 模型配置加密密钥
MODEL_CONFIG_SECRET=replace_with_a_long_random_secret_for_model_configs

# PR8 手动数据库备份配置
# Windows 示例：C:\Program Files\MySQL\MySQL Server 8.0\bin\mysqldump.exe
# Linux/Docker 示例：/usr/bin/mysqldump
MYSQLDUMP_BIN=replace_with_absolute_path_to_mysqldump

PORT=3000
